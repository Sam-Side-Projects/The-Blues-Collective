# Copy this file to ".env.local" and fill in real values.
# NEVER put real keys in this file — this template is safe to share/commit.

# ---- Supabase (database, auth, image storage) ----
# Find these in Supabase: Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ---- External football data (used by scheduled sync jobs only) ----
# football-data.org: register at https://www.football-data.org/client/register
FOOTBALL_DATA_API_TOKEN=your-football-data-token
# API-Football: register at https://www.api-football.com
API_FOOTBALL_KEY=your-api-football-key

# ---- Cron protection (secures scheduled jobs in production) ----
CRON_SECRET=a-long-random-string
